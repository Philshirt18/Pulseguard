SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token
OPENAI_API_KEY=sk-your-openai-key
PORT=3000

# Demo mode: uses polished fallback narratives (instant, no API calls)
# Set to true for reliable demo with zero latency
DEMO_MODE=false

# Proactive alerts: set a channel ID to receive automatic risk alerts on startup
# Get channel ID: right-click channel in Slack → "View channel details" → copy ID at bottom
# ALERT_CHANNEL=C0123456789
