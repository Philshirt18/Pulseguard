{
  "display_information": {
    "name": "PulseGuard AI",
    "description": "Detect business risks before they become business problems.",
    "background_color": "#1a1a2e"
  },
  "features": {
    "app_home": {
      "home_tab_enabled": true,
      "messages_tab_enabled": false,
      "messages_tab_read_only_enabled": false
    },
    "bot_user": {
      "display_name": "PulseGuard AI",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/executive-summary",
        "description": "Executive Intelligence Brief with critical risks and actions",
        "should_escape": false
      },
      {
        "command": "/risk-report",
        "description": "View all detected risks ranked by severity",
        "should_escape": false
      },
      {
        "command": "/why-risk",
        "description": "Deep root cause analysis for a specific risk",
        "usage_hint": "[risk-id]",
        "should_escape": false
      },
      {
        "command": "/recommend-action",
        "description": "Get recommended actions and expected business impact",
        "usage_hint": "[risk-id]",
        "should_escape": false
      },
      {
        "command": "/pulse",
        "description": "Quick risk status check",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "commands",
        "chat:write",
        "chat:write.public"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_home_opened"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
